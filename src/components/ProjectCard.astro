---
interface Props {
  title: string;
  description: string;
  status: 'active' | 'completed' | 'paused';
  tags?: string[];
  url?: string;
}

const { title, description, status, tags = [], url } = Astro.props;

const statusColors = {
  active: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  completed: 'bg-turmeric-100 text-turmeric-800 dark:bg-turmeric-900/30 dark:text-turmeric-400',
  paused: 'bg-cream-300 text-umber-600 dark:bg-charcoal-700 dark:text-cream-400',
};
---

<article class="p-6 rounded-2xl bg-cream-50 dark:bg-charcoal-800 border border-cream-300/50 dark:border-charcoal-700/50 shadow-warm-sm hover:shadow-warm transition-all duration-300">
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-serif text-lg font-semibold text-umber-800 dark:text-cream-100">
      {title}
    </h3>
    <span class={`flex-shrink-0 inline-block px-2.5 py-0.5 text-xs font-medium rounded-full ${statusColors[status]}`}>
      {status}
    </span>
  </div>
  <p class="text-umber-600 dark:text-cream-400 text-sm leading-relaxed mb-4">
    {description}
  </p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map((tag) => (
        <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-clay-100 text-umber-600 dark:bg-charcoal-700 dark:text-cream-400">
          {tag}
        </span>
      ))}
    </div>
  )}
  {url && (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      data-track="project_outbound_link"
      data-project-title={title}
      class="inline-flex items-center gap-1 text-sm text-saffron-500 hover:text-saffron-600 dark:text-saffron-400 dark:hover:text-saffron-300 transition-colors"
    >
      View project
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</article>
