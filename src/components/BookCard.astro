---
interface Props {
  title: string;
  author: string;
  status: 'reading' | 'finished' | 'queued';
  rating?: number;
  notes?: string;
}

const { title, author, status, rating, notes } = Astro.props;

const statusEmoji = {
  reading: '📖',
  finished: '✅',
  queued: '📋',
};
---

<article class="p-5 rounded-xl bg-cream-50 dark:bg-charcoal-800 border border-cream-300/50 dark:border-charcoal-700/50 shadow-warm-sm">
  <div class="flex items-start gap-4">
    <!-- Book icon placeholder -->
    <div class="flex-shrink-0 w-12 h-16 rounded-lg bg-gradient-to-br from-saffron-200 to-turmeric-200 dark:from-saffron-800 dark:to-turmeric-800 flex items-center justify-center text-lg">
      {statusEmoji[status]}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-serif text-base font-semibold text-umber-800 dark:text-cream-100 leading-snug">
        {title}
      </h3>
      <p class="text-sm text-umber-500 dark:text-cream-500 mt-0.5">{author}</p>
      {rating && (
        <div class="flex items-center gap-0.5 mt-2" aria-label={`Rating: ${rating} out of 5`}>
          {Array.from({ length: 5 }, (_, i) => (
            <svg
              class={`w-3.5 h-3.5 ${i < rating ? 'text-turmeric-400' : 'text-cream-300 dark:text-charcoal-700'}`}
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      )}
      {notes && (
        <p class="text-xs text-umber-500 dark:text-cream-500 mt-2 leading-relaxed italic">
          {notes}
        </p>
      )}
    </div>
  </div>
</article>
