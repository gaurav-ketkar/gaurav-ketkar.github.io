---
import BaseLayout from './BaseLayout.astro';
import KolamDivider from '../components/KolamDivider.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags?: string[];
    coverImage?: string;
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time
const content = await Astro.slots.render('default');
const words = content.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 250));
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="page-container py-16 sm:py-24">
    <!-- Header -->
    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-3 text-sm text-umber-500 dark:text-cream-500 mb-4">
        <time datetime={frontmatter.date.toISOString()}>{formattedDate}</time>
        <span class="text-cream-400 dark:text-charcoal-700">/</span>
        <span>{readingTime} min read</span>
      </div>
      <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-umber-800 dark:text-cream-100 leading-tight text-balance mb-6">
        {frontmatter.title}
      </h1>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {frontmatter.tags.map((tag) => (
            <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-clay-100 text-umber-600 dark:bg-charcoal-700 dark:text-cream-400">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <KolamDivider />

    <!-- Content -->
    <div class="prose prose-lg dark:prose-invert mx-auto">
      <slot />
    </div>

    <!-- Footer nav -->
    <KolamDivider />
    <nav class="flex justify-between items-center text-sm">
      <a href="/blog" class="inline-flex items-center gap-2 text-saffron-500 hover:text-saffron-600 dark:text-saffron-400 dark:hover:text-saffron-300 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All posts
      </a>
    </nav>
  </article>
</BaseLayout>
