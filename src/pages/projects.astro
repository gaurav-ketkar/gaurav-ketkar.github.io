---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects" description="Product initiatives and things I'm building.">
  <section class="page-container py-16 sm:py-24">
    <div class="max-w-2xl mb-12 reveal">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-umber-800 dark:text-cream-100 mb-4">
        Projects
      </h1>
      <p class="text-umber-600 dark:text-cream-400 leading-relaxed">
        Product initiatives I'm leading or have contributed to. These represent where I've 
        invested my craft and energy.
      </p>
    </div>

    <!-- Interactive Tools -->
    <div class="mb-12 reveal">
      <h2 class="font-serif text-xl font-semibold text-umber-700 dark:text-cream-200 mb-4">Interactive Tools</h2>
      <div class="grid gap-5 sm:grid-cols-2">
        <a href="/projects/practice" class="group rounded-xl border border-cream-300 dark:border-charcoal-700 bg-white dark:bg-charcoal-800 p-5 transition-all hover:shadow-md hover:border-saffron-300 dark:hover:border-saffron-700">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">🎸</span>
            <h3 class="font-serif text-lg font-bold text-umber-800 dark:text-cream-100 group-hover:text-saffron-500 transition-colors">Guitar &amp; Ukulele Practice</h3>
          </div>
          <p class="text-sm text-umber-500 dark:text-cream-400">Interactive chord diagrams, progressions, song chords, and a timed exercise mode.</p>
          <div class="flex gap-2 mt-3">
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">Guitar</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">Ukulele</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">Interactive</span>
          </div>
        </a>
        <a href="/tools/contact-cleaner.html" class="group rounded-xl border border-cream-300 dark:border-charcoal-700 bg-white dark:bg-charcoal-800 p-5 transition-all hover:shadow-md hover:border-saffron-300 dark:hover:border-saffron-700">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">📇</span>
            <h3 class="font-serif text-lg font-bold text-umber-800 dark:text-cream-100 group-hover:text-saffron-500 transition-colors">Contact Cleaner</h3>
          </div>
          <p class="text-sm text-umber-500 dark:text-cream-400">Declutter your address book — quick triage, smart cleanup, duplicate merging, and batch actions for hundreds of contacts.</p>
          <div class="flex gap-2 mt-3">
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">Productivity</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">vCard</span>
            <span class="text-xs px-2 py-0.5 rounded-full bg-cream-200 dark:bg-charcoal-700 text-umber-500 dark:text-cream-400">Interactive</span>
          </div>
        </a>
      </div>
    </div>

    {projects.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2">
        {projects.map((project) => (
          <div class="reveal">
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              status={project.data.status}
              tags={project.data.tags}
              url={project.data.url}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 reveal">
        <p class="text-umber-500 dark:text-cream-500 text-lg">
          Projects coming soon. Check back!
        </p>
      </div>
    )}
  </section>
</BaseLayout>
